---
import { Icon } from "astro-icon/components";

interface Props {
  icon: string;
  label: string;
  description: string;
}

const { icon, label, description } = Astro.props;
---

<div class="glass-panel h-full rounded-2xl p-5">
  <div class="mb-4 flex flex-row items-center gap-4">
    <div class="h-12 w-12 rounded-xl bg-white/10 p-3 ring-1 ring-white/10">
      <Icon name={icon} class="h-full w-full text-white" />
    </div>
    <h3 class="flex-1 font-bold text-white">
      {label}
    </h3>
  </div>
  <p class="leading-7 text-gray-300">
    {description}
  </p>
</div>
