---
import IconButton from "@/components/IconButton.astro";
---

<nav id="nav-wrapper" class="fixed top-0 right-0 left-0 z-50 border-b border-white/10 bg-black/85 backdrop-blur-xl">
  <div class="mx-auto flex h-16 max-w-7xl flex-row items-center gap-4 px-4">
    <a href="/" class="flex items-center gap-3 leading-none" aria-label="Fand Server 首页">
      <img src="/assets/logo/256x.png" alt="" class="block h-8 w-8 rounded-lg" />
      <span class="text-lg font-semibold tracking-tight text-white">Fand Server</span>
    </a>

    <div class="hidden items-center gap-1 sm:flex">
      <a class="px-3 py-2 text-sm font-medium text-gray-300 transition hover:text-white" href="/#overview">概览</a>
      <a class="px-3 py-2 text-sm font-medium text-gray-300 transition hover:text-white" href="/#performance">性能</a>
      <a class="px-3 py-2 text-sm font-medium text-gray-300 transition hover:text-white" href="/software/fand">核心</a>
      <a class="px-3 py-2 text-sm font-medium text-gray-300 transition hover:text-white" href="/downloads">下载</a>
      <a class="px-3 py-2 text-sm font-medium text-gray-300 transition hover:text-white" href="/javadocs">API</a>
    </div>

    <div class="grow"></div>

    <IconButton icon="icons/fontawesome/github-brands" label="GitHub" href="https://github.com/MC20018/Fand" external />
  </div>
</nav>
