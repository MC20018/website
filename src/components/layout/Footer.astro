---
import { Icon } from "astro-icon/components";

const hash = import.meta.env.GIT_COMMIT_HASH;
---

<footer class="mt-16 border-t border-white/10 bg-black py-10">
  <div class="m-auto max-w-7xl px-4">
    <div class="flex flex-col gap-8 md:flex-row">
      <div class="md:w-1/3">
        <a href="/" class="flex items-center gap-3">
          <img src="/assets/logo/256x.png" alt="" class="h-10 w-10 rounded-lg" />
          <span class="text-lg font-semibold text-white">Fand Server</span>
        </a>
        <p class="mt-4 max-w-md text-sm leading-6 text-gray-400">
          面向 Minecraft 服务端性能、插件 API 和技术服可配置性的实验性核心。
        </p>
      </div>

      <div class="grid flex-1 gap-8 text-sm sm:grid-cols-3">
        <div>
          <span class="font-semibold text-white">项目</span>
          <ul class="mt-4 space-y-2 leading-5 text-gray-400">
            <li><a href="/software/fand">核心介绍</a></li>
            <li><a href="/downloads">下载</a></li>
            <li><a href="/javadocs">API</a></li>
          </ul>
        </div>
        <div>
          <span class="font-semibold text-white">源码</span>
          <ul class="mt-4 space-y-2 leading-5 text-gray-400">
            <li><a href="https://github.com/MC20018/Fand" target="_blank" rel="noreferrer">GitHub</a></li>
            <li><a href="/contribute">贡献</a></li>
          </ul>
        </div>
        <div>
          <span class="font-semibold text-white">页面</span>
          <ul class="mt-4 space-y-2 leading-5 text-gray-400">
            <li><a href="/#performance">性能方向</a></li>
            <li><a href="/#vanilla">原版语义</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-8 flex flex-col gap-3 border-t border-white/10 pt-6 text-sm text-gray-500 md:flex-row md:items-center md:justify-between">
      <span>Fand Server 不是 Mojang Studios 或 Microsoft 的官方产品。</span>
      <div class="flex items-center gap-3">
        <a
          class="rounded-full p-2 text-gray-400 transition hover:bg-white/10 hover:text-white"
          href="https://github.com/MC20018/Fand"
          target="_blank"
          rel="noreferrer"
          aria-label="Fand Server GitHub"
        >
          <Icon name="icons/fontawesome/github-brands" class="size-5" />
        </a>
        <span>website @ {hash}</span>
      </div>
    </div>
  </div>
</footer>

<style>
  @reference "tailwindcss";
  footer a {
    @apply transition hover:text-white;
  }
</style>
