---
import Button from "@/components/input/Button.astro";
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Downloads"
  description="下载 Fand Minecraft 服务端核心。"
  keywords={["fand", "minecraft", "server", "downloads", "jar"]}
  canonical="/downloads"
>
  <header class="mx-auto flex max-w-5xl flex-col items-center px-4 pt-32 pb-20 text-center lg:pt-36">
    <div class="tech-label mb-5">DOWNLOADS</div>
    <h1 class="text-5xl font-semibold leading-tight text-white md:text-7xl">下载 Fand Server</h1>
    <p class="mt-6 max-w-3xl text-xl leading-8 text-gray-300">
      当前下载入口指向 Fand 的 GitHub 仓库。正式构建分发 API 接入后，这里会直接展示版本、构建号和变更记录。
    </p>

    <div class="glass-panel mt-10 w-full rounded-3xl p-6 text-left">
      <div class="flex flex-col gap-6 md:flex-row md:items-center">
        <img src="/assets/logo/256x.png" alt="" class="h-16 w-16 rounded-2xl" />
        <div class="flex-1">
          <h2 class="text-2xl font-black text-white">Fand Server</h2>
          <p class="mt-2 leading-7 text-gray-300">高性能 Minecraft 服务端核心，面向稳定性、插件 API 和原版语义兼容持续优化。</p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row">
          <Button variant="filled" href="https://github.com/MC20018/Fand" external>GitHub</Button>
          <Button variant="outlined" href="/software/fand">了解更多</Button>
        </div>
      </div>
    </div>
  </header>
</Layout>
